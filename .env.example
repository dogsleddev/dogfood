# Dogfood environment — copy to .env.local and fill in. .env.local is gitignored.
# The app runs with NONE of these set (in-memory seed + Scout's deterministic router).

# --- Scout (Anthropic) ---------------------------------------------------------
# Key-optional: without it Scout falls back to a deterministic keyword router.
ANTHROPIC_API_KEY=

# --- Data source ---------------------------------------------------------------
# Unset = in-memory generator (default). "supabase" = read the persistent record layer from Supabase.
DATASTORE=

# --- Supabase (only needed when DATASTORE=supabase) ----------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # server-only; never expose to the client
# DDL/migrations only. On an IPv4 network use the Session pooler host (see supabase/README.md).
SUPABASE_DB_URL=

# --- Edge access gate (middleware.ts) ------------------------------------------
# REQUIRED on any deployed/production instance: without both, production returns 503 (fail closed).
# Not enforced in local development.
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=
